OIDC_ENABLE=true

# S3-compatible storage (works with AWS, MinIO, Swift, R2, Backblaze, etc.)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Generate with: openssl rand -hex 32
AUTH_SECRET=

# OIDC provider (any OpenID Connect compliant issuer)
# e.g. https://accounts.google.com
#      https://keycloak.example.com/realms/myrealm
#      https://myapp.auth0.com
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

USER_BUCKETS=